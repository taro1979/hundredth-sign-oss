  "scripts": {
    "dev": "node scripts/run-with-env.mjs NODE_ENV=development -- tsx watch server/_core/index.ts",
    "build": "node scripts/build.mjs",
    "start": "node scripts/run-with-env.mjs NODE_ENV=production -- node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:push": "node scripts/db-push.mjs",
    "test:integration": "node scripts/run-with-env.mjs VITEST_MAX_THREADS=1 VITEST_MIN_THREADS=1 -- dotenv -e .env.e2e -- vitest run integration.test.ts --reporter=verbose --testTimeout=60000 --hookTimeout=60000",
    "test:e2e:setup": "node scripts/e2e-setup.mjs",
    "test:e2e": "dotenv -e .env.e2e -- playwright test",
    "manual:screenshots": "node scripts/run-with-env.mjs UPDATE_MANUAL_SCREENSHOTS=1 -- dotenv -e .env.e2e -- playwright test e2e/manual-screenshots.spec.ts",
    "signctl": "node scripts/signctl.mjs",
    "test:e2e:coverage": "node scripts/run-with-env.mjs NODE_V8_COVERAGE=./coverage/e2e-server -- dotenv -e .env.e2e -- playwright test --reporter=html,json",
    "test:e2e:report": "node scripts/e2e-report.mjs",
    "test:e2e:teardown": "node scripts/e2e-teardown.mjs"
  },
