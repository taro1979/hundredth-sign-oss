# Required
DATABASE_URL=mysql://root:password@127.0.0.1:3306/hundredth_sign
JWT_SECRET=replace-with-at-least-32-random-characters
APP_URL=http://localhost:4817

# Optional server settings
PORT=4817
NODE_ENV=development
TRUST_PROXY=false
DB_SSL=false

# Optional Redis-backed rate limiting
# REDIS_URL=redis://127.0.0.1:6379

# Optional email: AWS SES
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# AWS_SES_REGION=ap-northeast-1
# SES_FROM_EMAIL=contracts@example.com

# Optional email: SMTP fallback
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=contracts@example.com

# Optional storage and encryption
# STORAGE_PROXY_URL=
# STORAGE_PROXY_API_KEY=
# Generate 64-character hex keys with: openssl rand -hex 32
# STORAGE_ENCRYPTION_KEY=
# STORAGE_ENCRYPTION_KEY_PREV=
# PII_ENCRYPTION_KEY=
# PII_ENCRYPTION_KEY_PREV=

# Optional platform PDF signing
# PLATFORM_SIGNING_P12=
# PLATFORM_SIGNING_PASSPHRASE=

# Optional maintenance mode
# MAINTENANCE_MODE=false
# MAINTENANCE_BYPASS_SECRET=
# MAINTENANCE_ALLOWED_IPS=
# MAINTENANCE_RETRY_AFTER=3600

# Optional integration CLI defaults
# SIGN_BASE_URL=http://localhost:4817
# SIGN_API_KEY=
# SIGN_OUTPUT=json
